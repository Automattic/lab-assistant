    "url": "https://github.com/Automattic/lab-assistant.git"
  },
  "bugs": {
    "url": "https://github.com/Automattic/lab-assistant/issues"
  },
  "homepage": "https://github.com/Automattic/lab-assistant",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "test": "node --test",
    "test:cli": "node lab-assistant.js --help"
  },
  "dependencies": {
    "cli-progress": "^3.12.0",
    "lighthouse": "^13.3.0",
